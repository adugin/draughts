# ============================================================
# Borland Pascal — артефакты оригинальной DOS-сборки
# ============================================================

# Скомпилированные бинарники
*.exe
*.tpu

# Графические BGI-драйверы и шрифты Borland (чужая собственность)
*.bgi
*.chr

# Сторонние DOS-утилиты
*.com

# Сохранённые партии пользователя
*.sav

# Файл последней сессии (генерируется при выходе из программы)
draughts.his

# Изображения
*.gif

# Базы позиций (генерируются программой в процессе игры)
goodbase.dat
badbase.dat

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.egg
*.egg-info/
dist/
build/
*.whl
.eggs/

# Виртуальные окружения
.venv/
venv/
ENV/
env/

# Тесты и покрытие
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ============================================================
# IDE / редакторы
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~
*.bak

# ============================================================
# OS
# ============================================================

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
._*

# ============================================================
# Окружение и секреты
# ============================================================
.env
.env.*
!.env.example

# ============================================================
# Draughts Python — пользовательские данные
# ============================================================
*.json
!draughts/resources/*.json

